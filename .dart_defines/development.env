# ============================================================
# .dart_defines/development.env — LOCAL DEVELOPMENT VALUES
# ============================================================
# This file is safe to commit ONLY if it contains non-production
# values (local/dev Supabase project). 
# NEVER put production keys here.
#
# Usage:
#   flutter run --dart-defines=.dart_defines/development.env
#
# For production builds, use CI/CD environment variables.
# ============================================================
SUPABASE_URL=YOUR_DEV_SUPABASE_URL_HERE
SUPABASE_ANON_KEY=YOUR_DEV_ANON_KEY_HERE
